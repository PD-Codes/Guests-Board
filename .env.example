# Home Assistant URL (ohne abschließenden Schrägstrich)
HA_URL=https://your-homeassistant-url:8123

# Home Assistant Long-Lived Access Token
# Erstellen: HA → Profil (unten links) → Sicherheit → Token erstellen
HA_TOKEN=dein_token_hier

# Admin-Passwort für den Admin-Bereich
ADMIN_PASSWORD=dein_passwort_hier

# Geheimer Schlüssel für Flask-Sessions (zufälligen String verwenden)
SECRET_KEY=bitte_aendern_zufallsstring_hier
