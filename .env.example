# Home Assistant URL (no trailing slash)
HA_URL=https://your-homeassistant-url:8123

# Home Assistant Long-Lived Access Token
# Create one in HA: Profile (bottom left) → Security → Long-Lived Access Tokens
HA_TOKEN=your_token_here

# Admin password for the admin panel
ADMIN_PASSWORD=your_password_here

# Secret key for Flask session signing (use a long random string)
SECRET_KEY=change_me_random_string_here
